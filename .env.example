# Nixbot Configuration

# LLM Provider (anthropic | openai | openai-compatible)
NIXBOT_LLM_PROVIDER=openai-compatible

# API Key
# For Anthropic: ANTHROPIC_API_KEY
# For OpenAI: OPENAI_API_KEY
# For openai-compatible: use OPENAI_API_KEY
OPENAI_API_KEY=your-api-key-here

# Model name
NIXBOT_LLM_MODEL=glm-4-flash

# Base URL (for openai-compatible providers)
NIXBOT_LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4

# Paths (optional - defaults shown)
# NIXBOT_GROUPS_DIR=./groups
# NIXBOT_DATA_DIR=./data
# NIXBOT_SANDBOX_BIN=./result/bin/run-in-sandbox
