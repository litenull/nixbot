# Nanix Configuration

# LLM Provider (anthropic | openai | openai-compatible)
NANIX_LLM_PROVIDER=openai-compatible

# API Key
# For Anthropic: ANTHROPIC_API_KEY
# For OpenAI: OPENAI_API_KEY
# For openai-compatible: use OPENAI_API_KEY
OPENAI_API_KEY=your-api-key-here

# Model name
NANIX_LLM_MODEL=glm-4-flash

# Base URL (for openai-compatible providers)
NANIX_LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4

# Paths (optional - defaults shown)
# NANIX_GROUPS_DIR=./groups
# NANIX_DATA_DIR=./data
# NANIX_SANDBOX_BIN=./result/bin/run-in-sandbox
